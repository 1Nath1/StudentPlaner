<Window x:Class="Planer01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Planer01"
        mc:Ignorable="d"
        Title="Planer" Height="500" Width="850"
        Background = "#C38D9E"  WindowStartupLocation="CenterScreen"
        
        MinWidth="600" MinHeight="400">


    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- prawy panel -->
        <StackPanel Grid.Column="1" Margin="0,150,0,0">

            <Button Content="Zadania" 
                        FontSize="15"
                        Click="ShowTasks_Click"
                        Margin="5" 
                        Height="30"
                        Background="#F1E4F3" Foreground="Black" >
                <!-- zaokrąglone rogi guzików-->
                <Button.Template>
                    <ControlTemplate TargetType = "Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                >
                            <ContentPresenter 
                               
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Bottom"
                                RecognizesAccessKey="True" Margin="0,0,0,10"/>

                        </Border>
                    </ControlTemplate>
                </Button.Template>


            </Button>

            <Button Content="Przedmioty" 
                        FontSize="15" 
                        Click="ShowSubjects_Click" 
                        Margin="5"  
                        Height="30" 
                        Background="#F1E4F3">
                
                <!-- zaokrąglone rogi guzików-->
                <Button.Template>
                    <ControlTemplate TargetType = "Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        BorderBrush="Gray"
                        BorderThickness="1">
                            <ContentPresenter 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Bottom"
                                RecognizesAccessKey="True" Margin="0,0,0,10"/>

                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content= "Nieobecności"
                        FontSize="15" 
                        Click="ShowAbsenceCounter_Click" 
                        Margin="5"  
                        Height="30" 
                        Background="#F1E4F3">
                
                <!-- zaokrąglone rogi guzików-->
                <Button.Template>
                    <ControlTemplate TargetType = "Button">
                        <Border
                             Background="{TemplateBinding Background}"
                             CornerRadius="8"
                             Padding="{TemplateBinding Padding}"
                            BorderBrush="Gray"
                            BorderThickness="1">
                            <ContentPresenter 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Bottom"
                                 RecognizesAccessKey="True" Margin="0,0,0,10"/>

                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>

        <!-- lewy panel -->
        <Grid Grid.Column="0">
            <Grid x:Name="TasksView" Visibility="Collapsed">
                <!-- interfejs zadań -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="275*"/>
                </Grid.RowDefinitions>


                <!-- pole do wybrania przedmiotu -->
                <ComboBox x:Name="SubjectComboBox" Background="#F1E4F3"
                          Grid.Row="2"
                Height="30"
                Margin="400,0,10,10"   
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem IsEnabled="False" IsSelected="True">
                        Wybierz przedmiot</ComboBoxItem>
                   

                    <!-- do poprawy -->
                  <!--  <ComboBox.Template>
                        <ControlTemplate TargetType = "ComboBox">
                            <Border Background="{TemplateBinding Background}"
                                 CornerRadius="8"
                                 Padding="{TemplateBinding Padding}"
                                 BorderBrush="Gray"
                                 BorderThickness="1">
                                

                                <Grid>
                                    <ContentPresenter 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Bottom"
                                    RecognizesAccessKey="True" Margin="0,0,0,10"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ComboBox.Template>-->



                </ComboBox>
                <!-- Pole do wpisania zadania -->
                <TextBox x:Name="TaskTextBox" FontSize="17.5"
                Height="30"
                Margin="0,0,0,10"
                KeyDown="TaskTextBox_KeyDown" Background="#F1E4F3"
                />

                <!-- Przycisk dodawania -->
                <Button Grid.Row="1"
                 Content="Dodaj zadanie"
                 Height="30"
                 Click="AddTask_Click"
                 Margin="10,0,400,10"
                  Background="#F1E4F3">
                    <Button.Template>
                        <ControlTemplate TargetType = "Button">
                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                 Padding="{TemplateBinding Padding}"
                                 BorderBrush="Gray"
                                 BorderThickness="1">
                                
                                <ContentPresenter 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Bottom"
                                    RecognizesAccessKey="True" Margin="0,0,0,10"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                        <!-- Usuwanie ostatniego zadania -->
                <Button Grid.Row="1"
                 Content="Usuń ostatnie zadanie"
                 Height="30"
                 Click="RemoveTask_Click"
                 Margin="400,0,10,10" 
                        Background="#F1E4F3">
                    <Button.Template>
                <ControlTemplate TargetType = "Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="Gray"
                            BorderThickness="1">
                                <ContentPresenter 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Bottom"
                             RecognizesAccessKey="True" Margin="0,0,0,10"/>
                            </Border>
                </ControlTemplate>
                </Button.Template>
                </Button>
                <!-- Usuwanie wybranego zadania -->
                <Button Grid.Row="2"
                 Content="Usuń"
                 Height="29.5"
                 Click="RemoveSelectedTask_Click"
                 Margin="10,0,400,10"
                          Background="#F1E4F3"
                    >
                    <Button.Template>
                        <ControlTemplate TargetType = "Button">
                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                    BorderBrush="Gray"
                                    BorderThickness="1">
                                <ContentPresenter 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Bottom"
                                    RecognizesAccessKey="True" Margin="0,0,0,10"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Lista zadań -->
                <ListBox x:Name="TasksListBox" 
                Grid.Row="3" Grid.RowSpan="2"  FontSize="17.5"  Background="#E0BBE4" 
         
         MouseDoubleClick = "TasksListBox_MouseDoubleClick"/>
            </Grid>
            
            
            <!--  interfejs przedmiotów -->
            <Grid x:Name="SubjectsView" Visibility="Visible">
                
             

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="275*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Przedmioty" Grid.Row="0" FontSize="40" FontWeight="Bold" Margin="10" FontStyle="Italic" />
                <!-- dodawanie przedmiotu -->
                <Button Grid.Row="2" Grid.RowSpan="1" Width="32" HorizontalAlignment="Right" Background="#F1E4F3"
                Content="+" FontSize="20"
                Height="32"
                Click="AddSubject_Click"
                />

                <!-- Pole do wpisania nazwy przedmiotu -->
                <TextBox x:Name="SubjectTextBox" Grid.Row="2" Grid.RowSpan="1" FontSize="17.5" TextAlignment="Center" Background="#F1E4F3"
                Height="32"
                Margin="0,0,32,0"
                KeyDown="SubjectTextBox_KeyDown"/>


                <!-- Lista przedmiotów -->
                <ListBox x:Name="SubjectListBox"  FontSize="16"  Background="#E0BBE4" 
                Grid.Row="3" Grid.RowSpan="2" HorizontalContentAlignment="Center"
                MouseDoubleClick = "SubjectsListBox_MouseDoubleClick" >
                    
                    <!-- zaznaczanie itemu na liście-->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value=" True">
                                    <Setter Property="Background" Value="#B084F5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                   
                    <ListBox.ItemTemplate>
                        <DataTemplate>

                            <Border CornerRadius="8"
                               BorderBrush=" Gray"
                               BorderThickness="0,0,0,1"
                               Background="Transparent"
                               Margin="2"
                               Padding="0">


                                <StackPanel>

                                    <TextBlock Text="{Binding Name}"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="350"  
                           Margin="0,5"/>



                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>


            </Grid>

            <Grid x:Name="AbsenceCounterView" Visibility="Collapsed">
                <!--  interfejs licznika nieobecności -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="275*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Nieobecności" Grid.Row="0" FontSize="25" FontWeight="Bold" Margin="10" FontStyle="Italic"/>
                <!-- lista przedmiotów -->
                <ListBox x:Name="AbsenceSubjectListBox" Margin="0,0,250,0" FontSize="17.5"
                         Grid.Row="3" Grid.RowSpan="2"/>




            </Grid>

        </Grid>

    </Grid>
</Window>

<Window x:Class="Planer01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Planer01"
        mc:Ignorable="d"
        Title="Planer" Height="500" Width="850"
        Background = "LightPink">
        

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <!-- prawy panel -->
        <StackPanel Grid.Column="1">
            <Button Content="Zadania" Click="ShowTasks_Click" Margin="5"/>
            <Button Content="Przedmioty" Click="ShowSubjects_Click" Margin="5" Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
        </StackPanel>

        <!-- lewa część -->
        <Grid Grid.Column="0">
            <Grid x:Name="TasksView">
                <!-- TU wklejasz swój obecny interfejs zadań -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="275*"/>
                </Grid.RowDefinitions>


                <!-- pole do wybrania przedmiotu -->
                <ComboBox x:Name="SubjectComboBox"
                          Grid.Row="2"
                Height="30"
                Margin="400,0,10,10"   
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                >
                    <ComboBoxItem IsEnabled="False" IsSelected="True">  
                        Wybierz przedmiot</ComboBoxItem>
                    
                </ComboBox>
                <!-- Pole do wpisania zadania -->
                <TextBox x:Name="TaskTextBox"
                Height="30"
                Margin="0,0,0,10"
                KeyDown="TaskTextBox_KeyDown"
                />

                <!-- Przycisk dodawania -->
                <Button Grid.Row="1"
    Content="Dodaj zadanie"
    Height="30"
    Click="AddTask_Click"
    Margin="10,0,400,10"/>
                <!-- Usuwanie ostatniego zadania -->
                <Button Grid.Row="1"
        Content="Usuń ostatnie zadanie"
        Height="30"
        Click="RemoveTask_Click"
        Margin="400,0,10,10"/>
                <!-- Usuwanie wybranego zadania -->
                <Button Grid.Row="2"
        Content="Usuń"
        Height="29.5"
        Click="RemoveSelectedTask_Click"
        Margin="10,0,400,10"/>


                <!-- Lista zadań -->
                <ListBox x:Name="TasksListBox"
     Grid.Row="3" Grid.RowSpan="2"
         
         MouseDoubleClick = "TasksListBox_MouseDoubleClick"/>
            </Grid>

            <Grid x:Name="SubjectsView" Visibility="Collapsed">
                <!-- TU zrobimy interfejs przedmiotów -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="275*"/>
                </Grid.RowDefinitions>
                <!-- dodawanie przedmiotu -->
                <Button Grid.Row="1"
                Content="Dodaj przedmiot"
                Height="30"
                Click="AddSubject_Click"
                Margin="10,0,400,10"/>

                <!-- Pole do wpisania nazwy przedmiotu -->
                <TextBox x:Name="SubjectTextBox"
                Height="30"
                Margin="0,0,0,10"
                KeyDown="SubjectTextBox_KeyDown"/>


                <!-- Lista przedmiotów -->
                <ListBox x:Name="SubjectListBox"
                Grid.Row="3" Grid.RowSpan="2"
                MouseDoubleClick = "SubjectsListBox_MouseDoubleClick"/>
                
                
            </Grid>
        </Grid>

        
        
    </Grid>
</Window>
